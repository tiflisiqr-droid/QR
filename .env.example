# Copy to `.env.local` (gitignored) and fill from Supabase → Project Settings → API.

# MUST be the REST API URL (ends with .supabase.co), NOT the dashboard link.
# Example: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Project Settings → API → anon public key (long JWT)
VITE_SUPABASE_ANON_KEY=paste_your_anon_key_here

# GitHub Pages: add the SAME two names as "Repository secrets" (Settings → Secrets → Actions),
# otherwise the deployed site has no Supabase and the menu is per-browser (localStorage only).

# Optional: guest menu header — social & delivery (full URLs). If unset, app uses Batumi defaults in code.
# VITE_LINK_FACEBOOK=
# VITE_LINK_INSTAGRAM=
# VITE_LINK_GOOGLE=
# VITE_LINK_TRIPADVISOR=   (defaults to Tripadvisor search; set your listing URL when you have it)
# VITE_LINK_WOLT=
# VITE_LINK_GLOVO=
# VITE_LINK_BOLT=
