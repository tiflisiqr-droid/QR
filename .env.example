# Copy to `.env.local` (gitignored) and fill from Supabase → Project Settings → API.

# MUST be the REST API URL (ends with .supabase.co), NOT the dashboard link.
# Example: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=https://supabase.com/dashboard/project/uugugwkqdgyrnasmsaoj

# Project Settings → API → anon public key (long JWT)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV1Z3Vnd2txZGd5cm5hc21zYW9qIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY2ODU3NzAsImV4cCI6MjA5MjI2MTc3MH0.dcCIiTmY8sVXYTMNfo9hP13KUkaKX4eq5hOYvLJrsqU

# GitHub Pages: add the SAME two names as "Repository secrets" (Settings → Secrets → Actions),
# otherwise the deployed site has no Supabase and the menu is per-browser (localStorage only).
#
# Deploy stamp (optional locally): Actions sets VITE_DEPLOY_STAMP automatically; each value forces a new JS hash on Pages.
# VITE_DEPLOY_STAMP=local-test

# Optional: guest menu header — social & delivery (full URLs). If unset, app uses Batumi defaults in code.
# VITE_LINK_FACEBOOK=
# VITE_LINK_INSTAGRAM=
# VITE_LINK_GOOGLE=   (Google Business / Maps review page URL, e.g. https://g.page/r/…/review)
# VITE_LINK_TRIPADVISOR=   (optional override; default in code is Restaurant Tiflisi review page on Tripadvisor)
# VITE_LINK_WOLT=
# VITE_LINK_GLOVO=
# VITE_LINK_BOLT=
